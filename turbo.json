{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "coverage/**"
      ]
    },
    "@frollz2/api#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "@frollz2/ui#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "@frollz2/schema#build": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "@frollz2/api#test": {
      "outputs": []
    },
    "@frollz2/ui#test": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}