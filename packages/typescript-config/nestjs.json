{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "incremental": true,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": true,
        "removeComments": true,
        "verbatimModuleSyntax": true
    }
}