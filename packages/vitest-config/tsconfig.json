{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@frollz/typescript-config/base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "dist",
        "rootDir": "src",
        "strictNullChecks": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}