{
  "name": "@frollz2/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "dev": "pnpm --filter @frollz2/schema build && nest start --watch",
    "lint": "eslint --max-warnings 0 \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "pnpm --filter @frollz2/schema build && vitest run",
    "db:migrate": "pnpm --filter @frollz2/schema build && tsx src/infrastructure/migrate.ts",
    "db:seed": "pnpm --filter @frollz2/schema build && tsx src/infrastructure/seed.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@frollz2/schema": "workspace:*",
    "@mikro-orm/core": "^7.0.11",
    "@mikro-orm/decorators": "^7.0.11",
    "@mikro-orm/migrations": "^7.0.11",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.11",
    "@mikro-orm/sqlite": "^7.0.11",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.3.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "nestjs-zod": "^5.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "*",
    "@types/passport-jwt": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "*",
    "unplugin-swc": "^1.5.6",
    "vitest": "*"
  }
}
