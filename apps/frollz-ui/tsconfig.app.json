{
    "extends": "@frollz/typescript-config/vue.json",
    "compilerOptions": {
        "noEmit": true,
        "types": [
            "vite/client"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@frollz/shared": [
                "../../packages/shared/dist/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/**/*.vue"
    ],
    "exclude": [
        "src/**/__tests__/*"
    ]
}