    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "*",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "*",
    "vite": "^8.0.9",
    "vitest": "*",
    "vue-tsc": "^3.1.1"
  }
}
