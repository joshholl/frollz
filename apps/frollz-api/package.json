{
  "name": "@frollz/frollz-api",
  "version": "0.2.4",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rm -rf dist dev.db",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "NODE_ENV=development nest start --watch",
    "debug": "NODE_ENV=development nest start --debug --watch",
    "prod": "NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:integration": "NODE_ENV=test vitest run --config vitest.integration.config.ts",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "seed": "knex --knexfile knexfile.ts seed:run"
  },
  "dependencies": {
    "@frollz/shared": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "zod": "^4.3.6",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/throttler": "^6.5.0",
    "better-sqlite3": "^12.8.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.1",
    "helmet": "^8.1.0",
    "knex": "^3.2.9",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@frollz/vitest-config": "workspace:*",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@swc/core": "^1.15.26",
    "@types/better-sqlite3": "^7.6.13",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.4"
  }
}
