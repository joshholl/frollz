{
  "rule": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
      "rollId": {
        "type": "string",
        "description": "Human-readable identifier, format: roll-{stock-brand}-{YYYY-MM-DD}",
        "minLength": 1
      },
      "stockKey": {
        "type": "string",
        "description": "Reference to a stocks document _key",
        "minLength": 1
      },
      "state": {
        "type": "string",
        "enum": ["Added", "Frozen", "Refrigerated", "Shelved", "Loaded", "Finished", "Developed"]
      },
      "dateObtained": {
        "type": "string",
        "format": "date-time"
      },
      "obtainmentMethod": {
        "type": "string",
        "enum": ["Gift", "Purchase"]
      },
      "obtainedFrom": {
        "type": "string",
        "minLength": 1
      },
      "timesExposedToXrays": {
        "type": "integer",
        "minimum": 0
      },
      "imagesUrl": {
        "type": "string",
        "format": "uri"
      },
      "expirationDate": {
        "type": "string",
        "format": "date-time"
      },
      "createdAt": {
        "type": "string",
        "format": "date-time"
      },
      "updatedAt": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["rollId", "stockKey", "state", "dateObtained", "obtainmentMethod", "obtainedFrom", "timesExposedToXrays"],
    "additionalProperties": false
  },
  "level": "strict",
  "message": "Document does not conform to the rolls schema."
}
