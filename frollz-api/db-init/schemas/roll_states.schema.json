{
  "rule": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
      "stateId": {
        "type": "string",
        "description": "UUID identifying this state transition",
        "minLength": 1
      },
      "rollId": {
        "type": "string",
        "description": "Reference to a rolls document _key",
        "minLength": 1
      },
      "state": {
        "type": "string",
        "enum": ["Added", "Frozen", "Refrigerated", "Shelved", "Loaded", "Finished", "Developed"]
      },
      "date": {
        "type": "string",
        "format": "date-time"
      },
      "notes": {
        "type": "string"
      },
      "createdAt": {
        "type": "string",
        "format": "date-time"
      },
      "updatedAt": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["stateId", "rollId", "state", "date"],
    "additionalProperties": false
  },
  "level": "strict",
  "message": "Document does not conform to the roll_states schema."
}
