{
  "rule": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "type": "object",
    "properties": {
      "value": {
        "type": "string",
        "minLength": 1
      },
      "color": {
        "type": "string",
        "pattern": "^#[0-9A-Fa-f]{6}$"
      },
      "createdAt": {
        "type": "string",
        "format": "date-time"
      }
    },
    "required": ["value", "color", "createdAt"],
    "additionalProperties": false
  },
  "level": "strict",
  "message": "Document does not conform to the tags schema."
}
