# Copy this file to .env before running docker compose.
# Change credentials/secrets before exposing your deployment.

# Database runtime selection: postgres (recommended for compose) or sqlite
DATABASE_DRIVER=postgres

# Postgres runtime (used when DATABASE_DRIVER=postgres)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=frollz
DATABASE_USER=frollz
DATABASE_PASSWORD=changeme

# SQLite fallback (used when DATABASE_DRIVER=sqlite)
DATABASE_URL=frollz2.sqlite

# API runtime
JWT_ACCESS_SECRET=change-me
ALLOWED_ORIGINS=http://localhost
AUTO_MIGRATE_SEED=true
SEED_DEMO_USER=false
NODE_ENV=production
PORT=3000
