# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output ──────────────────────────────────────────────────────────────
frollz-api/dist/
frollz-ui/dist/

# ── SQLite development database ───────────────────────────────────────────────
frollz-api/dev.db

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
# Prevent tsc composite-mode from committing emitted files into src/
frollz-ui/src/**/*.js
frollz-ui/src/**/*.d.ts

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code local settings (personal overrides, not for version control) ──
.claude/
frollz-api/coverage
frollz-ui/coverage
frollz-api/dev.db
