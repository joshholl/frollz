{
  "name": "frollz2",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "cross-env NODE_ENV=development turbo run dev --parallel",
    "dev:web": "pnpm --filter @frollz2/web dev",
    "dev:mobile": "pnpm --filter @frollz2/mobile dev",
    "build": "turbo run build",
    "clean": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @frollz2/api db:migrate",
    "db:seed": "pnpm --filter @frollz2/api db:seed"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
