{
  "name": "frollz2",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development turbo run dev --parallel",
    "build": "turbo run build",
    "clean": "turbo run build",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @frollz2/api db:migrate",
    "db:seed": "pnpm --filter @frollz2/api db:seed"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
